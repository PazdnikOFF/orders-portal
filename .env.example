# ============================================================================
#  Order Tracking Portal — configuration. Copy to .env and adjust.
# ============================================================================

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Hostname(s) the portal answers on (comma-separated). Example for Bitrix host:
ALLOWED_HOSTS=orders.example.com,localhost,127.0.0.1
# Full external origins for CSRF (scheme required), comma-separated:
CSRF_TRUSTED_ORIGINS=https://orders.example.com
# Set True only if TLS is terminated and you want to force HTTPS redirects:
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- Host port published by nginx (NOT 80/443 — Bitrix24 uses those) ---
HTTP_PORT=8080

# --- PostgreSQL (internal container) ---
POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (internal container) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Initial administrator (created on first start if absent) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_FULL_NAME=Администратор

# --- Display timezone (storage is always UTC) ---
DISPLAY_TIME_ZONE=Europe/Moscow

# --- File uploads ---
ORDER_FILES_ROOT=/data/orders
FILE_UPLOAD_MAX_SIZE=26214400
FILE_UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip,rar,7z

# --- Backups (TЗ §5) ---
BACKUP_ROOT=/data/backups
BACKUP_RETENTION_DAYS=90
BACKUP_INTERVAL_HOURS=3

# --- Organization data provider by INN (TЗ §14) ---
# stub  = offline mock (no key, for development/demo)
# dadata = DaData findById/party (free tier, requires DADATA_API_KEY)
ORG_PROVIDER=stub
DADATA_API_KEY=
DADATA_SECRET_KEY=

# --- Google Drive sync via rclone (TЗ §6) ---
RCLONE_ENABLED=False
RCLONE_REMOTE=gdrive:orders
RCLONE_SYNC_INTERVAL_MINUTES=30
# Host directory containing rclone.conf (mounted into the worker, read-only):
RCLONE_CONFIG_DIR=./deploy/rclone

# --- Runtime sizing ---
GUNICORN_WORKERS=3
CELERY_CONCURRENCY=2
LOG_LEVEL=INFO
