# =============================================================================
# nginx vhost для портала заказов: turn.lidermedicina.ru
# =============================================================================
# Назначение: перехватить запросы поддомена turn.lidermedicina.ru и проксировать
# их в Docker-стек портала на 127.0.0.1:8080. Основные сайты Bitrix24
# (bitrix.lidermedicina.ru, test.lidermedicina.ru) НЕ затрагиваются — у них свои
# server-блоки с явными server_name.
#
# Куда положить:
#   /etc/nginx/bx/site_enabled/turn.conf
#
# После размещения файла:
#   sudo nginx -t                  # ОБЯЗАТЕЛЬНО — проверка синтаксиса
#   sudo systemctl reload nginx    # применить (основной сайт не перезапускается)
#
# Откат при любых проблемах:
#   sudo rm /etc/nginx/bx/site_enabled/turn.conf
#   sudo systemctl reload nginx
# =============================================================================

# ---------- HTTP -> HTTPS ----------
server {
    listen      80;
    server_name turn.lidermedicina.ru;
    server_name_in_redirect off;

    # Оставляем доступным ACME-challenge на случай продления certbot
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ---------- HTTPS — реверс-прокси на Docker-контейнер портала ----------
server {
    listen      443 ssl;
    http2       on;
    server_name turn.lidermedicina.ru;
    server_name_in_redirect off;

    # Сертификат уже выпущен certbot — используем его как есть
    ssl_certificate     /etc/letsencrypt/live/turn.lidermedicina.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/turn.lidermedicina.ru/privkey.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_session_cache   shared:SSL_turn:10m;
    ssl_session_timeout 1d;

    # Размер аплоада: файлы заказов до 25 МБ + запас
    client_max_body_size 30m;

    # Безопасность
    add_header X-Frame-Options        SAMEORIGIN  always;
    add_header X-Content-Type-Options nosniff     always;
    add_header Referrer-Policy        no-referrer-when-downgrade always;

    access_log /var/log/nginx/turn.lidermedicina.ru-access.log;
    error_log  /var/log/nginx/turn.lidermedicina.ru-error.log warn;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host  $host;

        proxy_connect_timeout 30s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;

        proxy_buffering         off;
        proxy_request_buffering off;
    }
}
